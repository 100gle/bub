---
interface NavLink {
  href: string;
  label: string;
  cta?: boolean;
}

const links: NavLink[] = [
  { href: "/en/", label: "Docs" },
  { href: "/en/architecture/", label: "Architecture" },
  { href: "/en/extension-guide/", label: "Extend" },
  { href: "https://github.com/bubbuild/bub", label: "GitHub" },
  { href: "/en/", label: "Get Started →", cta: true },
];
---

<nav class="sticky top-0 z-50 flex items-center justify-between px-4 md:px-12 h-[60px] bg-[rgba(13,15,26,0.8)] backdrop-blur-md border-b border-[rgba(255,255,255,0.08)]">
  <a class="text-2xl font-extrabold text-[#4f7eff] no-underline tracking-tight" href="/">bub</a>
  <ul class="flex gap-6 list-none items-center">
    {links.map((link) => (
      <li>
        {link.cta ? (
          <a href={link.href} class="px-4 py-1.5 rounded-md bg-[#4f7eff] text-white text-sm font-semibold no-underline transition-opacity hover:opacity-85">
            {link.label}
          </a>
        ) : (
          <a href={link.href} class="text-[#888b99] text-sm no-underline transition-colors hover:text-[#e8eaf6]">
            {link.label}
          </a>
        )}
      </li>
    ))}
  </ul>
</nav>
