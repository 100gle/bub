---
const steps = [
  "resolve_session",
  "load_state",
  "build_prompt",
  "run_model_stream",
  "render_outbound",
  "dispatch_outbound",
];
---

<section class="max-w-6xl mx-auto px-4 md:px-12 pb-20 md:pb-28 text-center">
  <p class="text-xs font-bold tracking-[0.12em] uppercase text-[#4f7eff] mb-2">Turn Lifecycle</p>
  <h2 class="text-[clamp(1.5rem,3vw,2.2rem)] font-extrabold tracking-tight mb-3">One pipeline. Every channel.</h2>
  <p class="text-[#888b99] max-w-xl mx-auto text-sm md:text-base mb-8">
    Every inbound message passes through the same hook-driven pipeline —
    CLI, Telegram, or any channel you add.
  </p>

  <div class="flex flex-wrap items-center justify-center gap-0 bg-[#1a1d2e] border border-[rgba(255,255,255,0.08)] rounded-xl px-5 py-6 mb-3 overflow-x-auto">
    {steps.map((step, i) => (
      <>
        <div class="flex flex-col items-center">
          <span class="bg-[rgba(79,126,255,0.12)] border border-[rgba(79,126,255,0.3)] text-[#4f7eff] rounded-lg px-3 py-1.5 text-[0.78rem] font-mono font-semibold whitespace-nowrap">
            {step}
          </span>
        </div>
        {i < steps.length - 1 && (
          <span class="text-[#888b99] text-lg leading-none px-1.5">→</span>
        )}
      </>
    ))}
  </div>
  <p class="text-xs text-[#888b99] font-mono">Each stage is a pluggy hook. Override any of them.</p>
</section>
