---
const steps = [
  "resolve_session",
  "load_state",
  "build_prompt",
  "run_model_stream",
  "render_outbound",
  "dispatch_outbound",
];
---

<section class="pipeline-section">
  <p class="section-label">Turn Lifecycle</p>
  <h2 class="section-title">One pipeline. Every channel.</h2>
  <p class="section-sub">
    Every inbound message passes through the same hook-driven pipeline —
    CLI, Telegram, or any channel you add.
  </p>
  <div class="pipeline">
    {steps.map((step, i) => (
      <>
        <div class="pipe-step">
          <span class="pipe-box">{step}</span>
        </div>
        {i < steps.length - 1 && <span class="pipe-arrow">→</span>}
      </>
    ))}
  </div>
  <p class="pipeline-caption">Each stage is a pluggy hook. Override any of them.</p>
</section>

<style>
  .pipeline-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem) clamp(3rem, 8vw, 5rem);
    text-align: center;
  }

  .pipeline {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem 1.25rem;
    margin-bottom: 0.75rem;
    overflow-x: auto;
  }

  .pipe-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .pipe-box {
    background: var(--accent-soft);
    border: 1px solid rgba(79, 126, 255, 0.3);
    color: var(--accent);
    border-radius: 8px;
    padding: 0.4rem 0.8rem;
    font-size: 0.78rem;
    font-family: var(--font-mono);
    font-weight: 600;
    white-space: nowrap;
  }

  .pipe-arrow {
    color: var(--text-muted);
    font-size: 1.1rem;
    padding: 0 0.3rem;
    line-height: 2.2;
  }

  .pipeline-caption {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }
</style>
