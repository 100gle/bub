---
interface Props {
  filename?: string;
}

const { filename } = Astro.props;
---

<div class="code-block">
  <div class="code-topbar">
    <span class="dot dot-r"></span>
    <span class="dot dot-y"></span>
    <span class="dot dot-g"></span>
    {filename && <span class="code-label">{filename}</span>}
  </div>
  <pre><code><slot /></code></pre>
</div>

<style>
  .code-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
  }

  .code-topbar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--surface-2);
    border-bottom: 1px solid var(--border);
  }

  .dot { width: 12px; height: 12px; border-radius: 50%; }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }

  .code-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-left: auto;
    font-family: var(--font-mono);
  }

  pre {
    margin: 0;
    padding: 1.25rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.7;
    overflow-x: auto;
    color: var(--text);
  }

  /* Syntax highlight spans — used by HeroSection's inline code */
  :global(.kw)  { color: #c792ea; }
  :global(.fn)  { color: #82aaff; }
  :global(.dec) { color: #ffcb6b; }
  :global(.str) { color: #c3e88d; }
  :global(.cm)  { color: var(--text-muted); }
  :global(.cls) { color: #f78c6c; }
</style>
