---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Bub — A common shape for agents that live alongside people.",
  description = "A common shape for agents that live alongside people.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content="Bub" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://bub.build" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="bg-[#0d0f1a] text-[#e8eaf6] font-sans min-h-screen antialiased leading-relaxed">
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/custom.css";

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  @media (prefers-color-scheme: light) {
    body {
      background-color: #f6f7fb;
      color: #0d0f1a;
    }
  }
</style>
