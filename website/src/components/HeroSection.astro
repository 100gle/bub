---
import CodeBlock from "./CodeBlock.astro";
---

<section class="hero">
  <div class="hero-text">
    <div class="hero-badge">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor">
        <circle cx="6" cy="6" r="6" />
      </svg>
      Group-chat native · Hook-first · Tape context
    </div>
    <h1 class="hero-title">
      A common shape for agents that live alongside
      <span>people.</span>
    </h1>
    <p class="hero-sub">
      Bub is a hook-first agent framework built for real collaboration —
      not demos. One pipeline. Every channel. Extensible at every stage.
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary" href="/en/">Get Started →</a>
      <a class="btn btn-secondary" href="https://github.com/bubbuild/bub">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        GitHub
      </a>
    </div>
  </div>

  <div class="hero-code" aria-hidden="true">
    <CodeBlock filename="plugin.py">
      <span class="kw">from</span> bub <span class="kw">import</span> hookimpl{"\n"}<span class="kw">from</span> republic <span class="kw">import</span> AsyncStreamEvents, StreamEvent{"\n\n"}<span class="cm"># Override any stage of the pipeline.</span>{"\n"}<span class="cm"># Builtins are just default plugins.</span>{"\n\n"}<span class="kw">class</span> <span class="cls">EchoPlugin</span>:{"\n"}{"    "}<span class="dec">@hookimpl</span>{"\n"}{"    "}<span class="kw">def</span> <span class="fn">build_prompt</span>(self, message, session_id, state):{"\n"}{"        "}<span class="kw">return</span> <span class="str">f"[echo] {"{"message['content']{"}"}"</span>{"\n\n"}{"    "}<span class="dec">@hookimpl</span>{"\n"}{"    "}<span class="kw">async def</span> <span class="fn">run_model_stream</span>(self, prompt, ...):
{"\n"}{"        "}<span class="kw">async def</span> <span class="fn">_iter</span>():{"\n"}{"            "}<span class="kw">yield</span> StreamEvent(<span class="str">"text"</span>, {"{\"delta\": prompt}"}){"\n"}{"        "}<span class="kw">return</span> AsyncStreamEvents(_iter())
    </CodeBlock>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(4rem, 10vw, 8rem) clamp(1rem, 4vw, 3rem) clamp(3rem, 8vw, 6rem);
  }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; }
    .hero-code { display: none; }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid rgba(79, 126, 255, 0.25);
    border-radius: 999px;
    padding: 0.25rem 0.85rem;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .hero-title span { color: var(--accent); }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
</style>
